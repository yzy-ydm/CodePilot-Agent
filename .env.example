# Database
POSTGRES_USER=codepilot
POSTGRES_PASSWORD=codepilot_secret
POSTGRES_DB=codepilot
DATABASE_URL=postgresql+asyncpg://codepilot:codepilot_secret@localhost:5432/codepilot

# JWT
